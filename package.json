{
  "name": "ashitakanji",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "track-a:build": "node scripts/build-jlpt-db.mjs",
    "track-a:naver-examples": "node scripts/collect-naver-examples.mjs",
    "track-a:translate": "node scripts/build-jlpt-db.mjs --translate",
    "release-gate": "node scripts/release-gate.mjs",
    "ci-check": "npm run typecheck && npm run test && npm run lint",
    "release-check": "npm run ci-check && npm run release-gate"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-sharing": "~13.1.5",
    "expo-speech": "~13.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-tracking-transparency": "~5.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^15.8.3",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0",
    "ts-fsrs": "^4.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~9.2.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3",
    "vitest": "^2.1.0"
